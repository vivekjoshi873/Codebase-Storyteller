# Backend + Docker Compose
POSTGRES_USER=codebase_user
POSTGRES_PASSWORD=codebase_password
POSTGRES_DB=codebase

# Local uvicorn on your PC → use localhost (see README).
# Backend inside Docker Compose → use @db:5432 instead of @localhost:5432
DATABASE_URL=postgresql+asyncpg://codebase_user:codebase_password@localhost:5432/codebase

# Required for AI chat answers.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Chat model (gpt-4o-mini is faster and cheaper than gpt-4o).
OPENAI_MODEL=gpt-4o-mini

# Optional backend settings.
CHROMA_PERSIST_DIR=./chroma_data
EMBED_MODEL=all-MiniLM-L6-v2

# Frontend dev proxy.
# Docker Compose already sets this for the frontend container.
# If you run frontend locally with npm, copy frontend/.env.example to frontend/.env.local.
VITE_PROXY_TARGET=http://localhost:8000
